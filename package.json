{
  "name": "@c9up/ream",
  "version": "0.1.0",
  "description": "Ream — Rust-powered Node.js application framework",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
