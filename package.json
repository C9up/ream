    "lint": "biome check src/"
  },
  "dependencies": {
    "reflect-metadata": "^0.2"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "vitest": "^3",
    "@biomejs/biome": "^1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
