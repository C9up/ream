{
  "name": "@c9up/ream",
  "version": "0.1.0",
  "description": "Ream — Rust-powered Node.js application framework",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./services/app": {
      "import": "./src/services/app.ts",
      "types": "./src/services/app.ts"
    },
    "./services/router": {
      "import": "./src/services/router.ts",
      "types": "./src/services/router.ts"
    },
    "./services/server": {
      "import": "./src/services/server.ts",
      "types": "./src/services/server.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:rust": "cargo build --release",
    "test": "vitest run",
    "test:rust": "cargo test --all",
    "lint": "biome check src/"
  },
  "dependencies": {
    "reflect-metadata": "^0.2"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "vitest": "^3",
    "@biomejs/biome": "^1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
